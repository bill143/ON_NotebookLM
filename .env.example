# ─────────────────────────────────────────────────────────────
# Nexus Notebook 11 LM — Environment Configuration
# Codename: ESPERANTO
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME="Nexus Notebook 11 LM"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_2024@localhost:5432/nexus_notebook_11
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── Authentication (Supabase SSR — ADR-5) ────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=change-me-in-production-32-bytes!
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
CSRF_SECRET=change-me-in-production-csrf!!!

# ── AI Providers (ADR-1 — Esperanto Pattern) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Local Models (ADR-7) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
KOKORO_TTS_BASE_URL=http://localhost:8880

# ── TTS Providers (ADR-4) ───────────────────────────────────
ELEVENLABS_API_KEY=
EDGE_TTS_ENABLED=true

# ── Storage ─────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Observability ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=nexus-notebook-11

# ── Cost Tracking ───────────────────────────────────────────
COST_TRACKING_ENABLED=true
BUDGET_ALERT_WEBHOOK=

# ── Encryption ──────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-byte-key-for-prod!!
